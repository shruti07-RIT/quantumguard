{
  "name": "quantumguard-backend",
  "version": "1.0.0",
  "description": "QuantumGuard Farmer Identity Backend — Node.js + MongoDB + Ethereum",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "compile": "npx hardhat compile",
    "deploy":  "npx hardhat run scripts/deploy.js --network sepolia"
  },
  "dependencies": {
    "axios":        "^1.6.0",
    "bcrypt":       "^5.1.1",
    "cors":         "^2.8.5",
    "crypto-js":    "^4.2.0",
    "dotenv":       "^16.3.1",
    "ethers":       "^6.8.1",
    "express":      "^4.18.2",
    "form-data":    "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose":     "^8.0.3",
    "multer":       "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat":  "^2.19.0",
    "nodemon":  "^3.0.2"
  }
}
